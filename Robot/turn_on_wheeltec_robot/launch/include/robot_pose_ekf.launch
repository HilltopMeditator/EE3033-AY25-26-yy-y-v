<launch>
  <!--no filtering when choosing cartogapher algorithm-->
  <arg name="is_cartographer" default="false"/>

  <!-- IMU correction node -->
  <node pkg="turn_on_wheeltec_robot" type="imu_correction.py" name="imu_corrector" output="screen" />

  <!-- Robot pose Extended Kalman filter -->
  <node pkg="robot_pose_ekf" type="robot_pose_ekf" name="robot_pose_ekf" output="screen" unless="$(arg is_cartographer)">
    <param name="output_frame" value="odom_combined"/>
    <param name="base_footprint_frame" value="base_footprint"/>
    <param name="freq" value="30.0"/>
    <param name="sensor_timeout" value="2.0"/>
    <param name="odom_used" value="true"/>
    <param name="imu_used" value="true"/>
    <param name="vo_used" value="false"/>
    <!-- Remapping imu data to corrected IMU -->
    <remap from="imu_data" to="imu_corrected" />
  </node>

</launch>



